{
  "rules": {
    ".read": false,
    ".write": false,
    "displays": {
      ".read": true,
      "$displayId": {
        "meta": {
          ".read": true
        },
        "repos": {
          ".read": true,
          "$repoId": {
            ".read": true,
            ".validate": "newData.hasChildren(['status'])"
          }
        }
      }
    }
  }
}
