{
  "rules": {
    ".read": false,
    ".write": false,
    "displays": {
      ".read": true,
      "$displayId": {
        "meta": {
          ".read": true
        },
        "repos": {
          ".read": true,
          "$repoId": {
            ".read": true,
            ".validate": "newData.hasChildren(['status'])"
          }
        }
      }
    },
    "agents": {
      ".read": true,
      ".write": false,
      "$agentId": {
        ".validate": "$agentId == 'claude' || $agentId == 'codex' || $agentId == 'meta' || $agentId == '_events'"
      }
    }
  }
}
