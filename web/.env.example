# ============================================================
#  Configuración pública de Firebase para la web app.
#  Estos valores NO son secretos (van embebidos en el frontend),
#  pero se cargan por variables de entorno para no fijar el proyecto.
#  Copiá este archivo a `web/.env` y completá con tu proyecto.
#  Obtenelos con:  firebase apps:sdkconfig web --project <projectId>
# ============================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
