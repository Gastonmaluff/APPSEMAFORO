# ============================================================
#  Config del forwarder de hooks de agentes (NO versionar valores reales).
#  Copiá estos valores a %USERPROFILE%\.agent-hook\config.json como:
#    { "url": "<AGENT_HOOK_URL>", "secret": "<AGENT_HOOK_SECRET>" }
#  o exportá estas variables de entorno antes de correr el forwarder/simulador.
#
#  El secreto es el MISMO que se guarda en Secret Manager como AGENT_HOOK_SECRET
#  y autentica el POST al endpoint. Nunca va en el frontend ni en el repo.
# ============================================================

# URL pública del endpoint (se obtiene tras desplegar la function agentHook):
AGENT_HOOK_URL=https://us-central1-steamdeck-semaforo.cloudfunctions.net/agentHook

# Secreto compartido (generar con: openssl rand -hex 32  ó  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AGENT_HOOK_SECRET=
