    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\gafa9\\OneDrive\\Escritorio\\WEBAPP STEAMDECK\\scripts\\agent-hook-forwarder.mjs\" --source codex --event session_end",
